# --- Environment ---
ENV=dev

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=2000
ANTHROPIC_MONTHLY_CAP_USD=20.0

# --- Finnhub (https://finnhub.io free tier) ---
FINNHUB_API_KEY=...

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGc...   # service role key (server-side only)

# --- Cache TTL ---
NARRATIVE_CACHE_HOURS=24
PRICE_CACHE_MINUTES_MARKET_OPEN=60
PRICE_CACHE_HOURS_MARKET_CLOSED=24

# --- CORS ---
# Comma-separated origins. Default dev: vite on :5173
CORS_ORIGINS=["http://localhost:5173"]

# --- Proxy (solo postazione INAIL) ---
# HTTP_PROXY=http://proxy.inail.it:8080
# HTTPS_PROXY=http://proxy.inail.it:8080
# NO_PROXY=localhost,127.0.0.1
